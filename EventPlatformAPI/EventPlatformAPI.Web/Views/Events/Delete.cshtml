@model EventPlatformAPI.Web.ViewModels.Events.EventViewModel

@{
    ViewData["Title"] = "Brisanje doga?aja";
}

<h1>Brisanje doga?aja</h1>
<h4>Da li ste sigurni?</h4>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Greška!</strong>
        <div asp-validation-summary="All"></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<dl class="row">
    <dt class="col-sm-3">Naziv</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Datum i vreme</dt>
    <dd class="col-sm-9">@Model.DateTime.ToString("dd.MM.yyyy HH:mm")</dd>
    <dt class="col-sm-3">Tip</dt>
    <dd class="col-sm-9">@Model.TypeName</dd>
    <dt class="col-sm-3">Lokacija</dt>
    <dd class="col-sm-9">@Model.LocationName</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Obriši</button>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</form>
