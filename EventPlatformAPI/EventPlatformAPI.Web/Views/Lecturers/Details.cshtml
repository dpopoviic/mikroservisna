@model EventPlatformAPI.Web.ViewModels.Lecturers.LecturerViewModel

@{
    ViewData["Title"] = "Detalji predavača";
}

<h1>Detalji predavača</h1>

<dl class="row">
    <dt class="col-sm-2">Ime</dt>
    <dd class="col-sm-10">@Model.FirstName</dd>
    <dt class="col-sm-2">Prezime</dt>
    <dd class="col-sm-10">@Model.LastName</dd>
    <dt class="col-sm-2">Titula</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Oblast stru?nosti</dt>
    <dd class="col-sm-10">@Model.Field</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Izmeni</a>
<a asp-action="Index" class="btn btn-secondary">Nazad</a>
