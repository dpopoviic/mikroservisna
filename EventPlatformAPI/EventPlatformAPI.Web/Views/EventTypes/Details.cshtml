@model EventPlatformAPI.Web.ViewModels.EventTypes.EventTypeViewModel

@{
    ViewData["Title"] = "Detalji tipa događaja";
}

<h1>Detalji tipa događaja</h1>

<dl class="row">
    <dt class="col-sm-2">Naziv</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Opis</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Izmeni</a>
<a asp-action="Index" class="btn btn-secondary">Nazad</a>
