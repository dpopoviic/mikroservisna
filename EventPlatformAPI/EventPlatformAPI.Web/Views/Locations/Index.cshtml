@model IEnumerable<EventPlatformAPI.Web.ViewModels.Locations.LocationViewModel>

@{
    ViewData["Title"] = "Lokacije";
}

<h1>Lokacije</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova lokacija</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Adresa</th>
            <th>Kapacitet</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Name</td>
            <td>@item.Address</td>
            <td>@item.Capacity</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Izmeni</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Detalji</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Obriši</a>
            </td>
        </tr>
}
    </tbody>
</table>
